# PostgreSQL (used by docker-compose for the postgres service)
POSTGRES_USER=adforge
POSTGRES_PASSWORD=password

# Database connection (backend uses this; docker-compose overrides host to 'postgres')
DATABASE_URL=postgres://adforge:password@localhost:5432/adforge

# LLM
OPENAI_API_KEY=sk-...

# Image & Video Generation
FAL_KEY=...
HEYGEN_API_KEY=...

# Text-to-Speech
ELEVENLABS_API_KEY=...

# Workers
WORKER_COUNT=3
